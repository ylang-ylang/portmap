PORTMAP_HTTP_BIND=0.0.0.0
PORTMAP_HTTP_PORT=8080

PORTMAP_CATALOG_BIND=0.0.0.0
PORTMAP_CATALOG_PORT=80

PORTMAP_DNS_BIND=192.168.201.52
PORTMAP_DNS_PORT=53
PORTMAP_DNS_TARGET_IP=192.168.201.52
PORTMAP_DNS_DOMAIN=debug.lan

PORTMAP_GATEWAY_NETWORK=portmap_gateway

# Host-wide raw/range port allocation pool. This is not per-branch generated
# state; each worktree still writes its own .portmap/state.json.
PORTMAP_STATE_DIR=~/.local/state/portmap

# Optional Docker Compose plugin shim switch. The gateway containers do not
# consume this; it controls local broker takeover.
PORTMAP_COMPOSE_TAKEOVER=0
